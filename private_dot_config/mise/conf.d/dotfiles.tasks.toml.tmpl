[tasks.dotfiles-nuke]
  description = "Nuke your whole dotfiles installation. Clean start."
  confirm="Nuke it all. Are you sure?"
  run = """
  mise run dotfiles-cleanup
  mise run dotfiles-unbrew
  mise run dotfiles-unmise
  """

[tasks.dotfiles-unbrew]
  description = "Uninstall Homebrew"
  run = """
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/uninstall.sh)"
  rm -rf {{ .homebrew_prefix }}
  """

[tasks.dotfiles-unmise]
  description = "Uninstall Mise"
  run = "sudo mise implode --config --yes"
