
if status is-interactive
    # Set the theme to Carbonfox (EdenEast)
    # Note: Fish themes are usually set once via 'fish_config theme choose'
    # but you can force it here if you want it to persist across different machines.
    if type -q fish_config
        # This assumes you have the theme installed or are using a compatible term color scheme
        # Carbonfox is a terminal-level color scheme; fish inherits those colors.
    end

    # Set key bindings
    #set -g fish_key_bindings fish_default_key_bindings
    set -g fish_key_bindings fish_vi_key_bindings
end
