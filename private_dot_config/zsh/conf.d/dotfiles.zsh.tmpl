#!/usr/bin/env zsh

# Check dotfile repo for updates every 4 days
fetch_head="{{ .chezmoi.sourceDir }}/.git/FETCH_HEAD"

# Get mtime: try macOS form first, fall back to Linux, then 0 on fresh installs.
ts=$(stat -f '%m' "$fetch_head" 2>/dev/null || stat -c '%Y' "$fetch_head" 2>/dev/null || echo 0)

# Compute 4-day threshold portably — avoids date -v (macOS-only) and date -d (Linux-only).
threshold=$(( $(date +%s) - 345600 ))

if [ "$ts" -lt "$threshold" ]; then
  # Only attempt fetch if the directory is actually a git repo
  if [ -d "{{ .chezmoi.sourceDir }}/.git" ]; then
    git -C "{{ .chezmoi.sourceDir }}" fetch 2>/dev/null

    # Check status for "behind" message
    if git -C "{{ .chezmoi.sourceDir }}" status -sb 2>/dev/null | grep -q "behind"; then
      FG_CYAN=$(tput setaf 6)
      RESET=$(tput sgr0)
      echo "\nNew dotfile updates available 😎! Run ${FG_CYAN}chezmoi update${RESET} to get them."
    fi
  fi
fi

