#!/usr/bin/env zsh

_printers

function fonts() {
  if [[ "$TERM" != xterm-kitty ]]; then
    echo
    _print_error "This script requires Kitty terminal🐱"
    {{ template "prompt_kitty.zsh" . }}
    return
  fi

  kitten choose-font

  sleep 1

  {{ if eq .chezmoi.os "darwin" -}}
    kill -sigUsr1 $KITTY_PID > /dev/null
  {{- else if eq .chezmoi.os "linux" }}
    kill -SIGUSR1 $KITTY_PID > /dev/null
  {{- end }}
}
fonts "$@"
