#! /usr/bin/env zsh

{{ template "printers.zsh" }}
{{ template "prompt_sudo.zsh" }}
{{ template "keep_in_dock.zsh" }}

_print_running_script "$0"

# Zsh Best Practice: Use a specific path for brew if possible,
# but falling back to 'brew' in PATH is more portable.
local BREW_PATH="{{ .homebrew_prefix }}/bin/brew"

# Install Homebrew ---
if [[ ! -x "$BREW_PATH" ]]; then
  _print_installing "homebrew"
  _prompt_sudo

  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  # Check if install actually worked
  if [[ ! -x "$BREW_PATH" ]]; then
    _print_error "Homebrew installation failed or binary not found at $BREW_PATH"
    exit 1
  fi
else
  _print_exists "homebrew"
fi

if ! (( $+commands[brew] )); then
  eval "$($BREW_PATH shellenv)"
fi

echo
_print_prog brew "update"
brew update --quiet

# Remove non-homebrew VSCode app
if [[ -d "/Applications/Visual Studio Code.app" ]]; then
  if ! brew list --cask visual-studio-code &>/dev/null; then
    echo
    _print_info "Moving Visual Studio Code to Homebrew-managed version..."

    # Graceful shutdown
    osascript -e 'quit app "Visual Studio Code"' 2>/dev/null

    _prompt_sudo
    sudo rm -rf "/Applications/Visual Studio Code.app"

    # Surgical symlink removal
    [[ -L "/usr/local/bin/code" ]] && sudo rm -f "/usr/local/bin/code"

    if [[ $? -ne 0 ]]; then
      _print_error "Could not remove manual VS Code install. Please remove it manually."
    fi
  fi
fi

echo
if [[ ! -f "$HOME/Brewfile" ]]; then
  _print_error "No Brewfile found at $HOME/Brewfile"
  exit 1
fi

# Bundle
_print_prog brew "bundle"
brew bundle --file="$HOME/Brewfile"

echo
_print_info "cleaning up..."
brew autoremove

echo
keep_in_dock "Figma"
keep_in_dock "Postman"
keep_in_dock "Visual Studio Code"
keep_in_dock "Zed"
killall Dock &> /dev/null

echo
_print_ok
