#! /usr/bin/env zsh

{{ template "printers.zsh" }}
{{ template "prompt.zsh" }}
{{ template "keep_in_dock.zsh" }}

_print_running_script "$0"

echo -e "\n${FG_YELLOW}[running script]${RESET} $0\n"

set -euo pipefail

{{ template "rvm_implode.zsh" }}

# Copy .zsh_history to ~/.local/share/zsh
ZSH_STATE_DIR="{{ .chezmoi.homeDir }}/.local/state/zsh"
[[ -d "$ZSH_STATE_DIR" ]] || mkdir -p "$ZSH_STATE_DIR"
if [[ -f "{{ .chezmoi.homeDir }}/.zsh_history" && ! -f "$ZSH_STATE_DIR/history" ]]; then
  echo
  _print_running "cp ~/.zsh_history to ~/.local/state/zsh/history"
  cp "{{ .chezmoi.homeDir }}/.zsh_history" "$ZSH_STATE_DIR/history"
fi

# Kitty
echo
_print_installing "kitty"
curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin launch=n

{{ if eq .chezmoi.os "darwin" }}
  # Keep kitty in dock
  keep_in_dock "kitty"
  killall Dock &> /dev/null
{{ end }}

echo
_print_ok
