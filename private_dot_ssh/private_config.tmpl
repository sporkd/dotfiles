# Do not add your own configs to this file!
# Instead add new files to the ~/configs.d directory
# which will all get included by this file.
# E.g. ~/.ssh/config.d/config.local

Include config.d/*

Host *
  AddKeysToAgent yes
  UseKeychain yes
  # SetEnv TERM=xterm

Host github.com
  HostName github.com
  IdentitiesOnly yes
  IdentityFile ~/.ssh/sporkd_ed25519
  User sporkd

Host hub.openingdesign.com
  HostName hub.openingdesign.com
  IdentitiesOnly yes
  IdentityFile ~/.ssh/sporkd_ed25519
  User peter

